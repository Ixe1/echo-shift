{
  "name": "echo-shift",
  "version": "0.1.0",
  "private": true,
  "author": "Paul Lewis (Ixe1)",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node scripts/preview-processes.mjs guard",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "preview:stop": "node scripts/preview-processes.mjs stop",
    "preview:restart": "npm run preview:stop && npm run build && npm run preview",
    "test:sim": "node scripts/simulation-check.mjs",
    "qa:door-solid": "node scripts/door-solid-render-check.mjs",
    "qa:core-spill": "node scripts/core-spill-render-check.mjs",
    "qa:editor": "node scripts/editor-smoke.mjs"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
